          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "As a new user, I want to register an account"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Acceptance Criteria: "
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "1. User can register with valid email and password "
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "2. Password must be at least 8 characters "
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "3. Email must be unique "
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "4. Confirmation email is sent after registration"
            }
          ]
        }
      ]
    },
